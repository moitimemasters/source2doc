# Local-only UI / preset config containing real LLM api_key. There is no
# *.example variant in the public tree — generate your preset through the
# admin UI at /admin/presets instead.
config.ui.yaml

.worktrees

# Local-dev component configs that may contain real LLM keys. The docker-mounted
# config files (`core/{gateway,worker}/config.docker.yaml`) are checked in —
# they reference secrets via `${ENCRYPTION_KEY}` / `${ADMIN_PASSWORD_HASH}` /
# `${POSTGRES_PASSWORD}`, populated from `.env` (which IS gitignored).
core/gateway/config.yaml
core/worker/config.yaml
core/codetour/config.yaml
core/mvp/configs/config.yaml
