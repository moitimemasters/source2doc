WORKER_ID=worker-1
REDIS_URL=redis://localhost:6379

# Generate with: ../../generate-encryption-key.sh "your-passphrase"
# IMPORTANT: Must match ENCRYPTION_KEY in root .env and gateway config
ENCRYPTION_KEY=YOUR_ENCRYPTION_KEY_HERE

POLL_INTERVAL_MS=1000
MAX_RETRIES=3
RETRY_DELAY_MS=5000

# PostgreSQL (for task metadata)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DATABASE=docgen
POSTGRES_USER=docgen
POSTGRES_PASSWORD=docgen_password

# S3 (LocalStack for development)
S3_ENDPOINT_URL=http://localhost:4566
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=test
S3_SECRET_ACCESS_KEY=test
S3_BUCKET=source2doc-repos
