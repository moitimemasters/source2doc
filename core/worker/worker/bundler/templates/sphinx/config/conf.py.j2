project = '{{ project_name }}'
copyright = '{{ copyright }}'
author = '{{ author }}'
release = '{{ release }}'

extensions = [
    'sphinx.ext.autodoc',
    'sphinx.ext.viewcode',
    'sphinx.ext.napoleon',
    'sphinx.ext.intersphinx',
    'sphinxcontrib.mermaid',
    'sphinx_togglebutton',
    'sphinx_design',
    'myst_parser',
]

templates_path = ['_templates']

# Without this, sphinx-build crawls colocated venvs / build output and
# floods the log with "document isn't included in any toctree" warnings,
# which become errors under -W.
exclude_patterns = [
    '_build',
    'Thumbs.db',
    '.DS_Store',
    '.venv',
    'venv',
    'env',
    'node_modules',
    'requirements.txt',
    'Dockerfile',
    'README.md',
    '_toc.md',
    'toc.json',
    'mermaid',
]

source_suffix = {
    '.rst': 'restructuredtext',
    '.md': 'markdown',
}

master_doc = 'index'

html_theme = 'sphinx_rtd_theme'
html_static_path = []

html_theme_options = {
    'navigation_depth': 4,
    'collapse_navigation': False,
    'sticky_navigation': True,
    'includehidden': True,
    'titles_only': False,
}

mermaid_version = "latest"

myst_enable_extensions = [
    "colon_fence",
    "deflist",
    "fieldlist",
    "html_admonition",
    "html_image",
    "linkify",
    "replacements",
    "smartquotes",
    "strikethrough",
    "substitution",
    "tasklist",
]
