worker_id: "${WORKER_ID}"

llm:
  provider: openai-compatible
  model: default
  api_key: API_KEY
  base_url: YOUR_LLM_BASE_URL_HERE
  temperature: 0.3
  max_tokens: 8000


redis:
  url: "redis://redis:6379"
  stream_prefix: "events"
  consumer_group: "workers"
  consumer_name: "worker-1"
  block_timeout_ms: 5000
  max_idle_time_ms: 120000
  stream_ttl_seconds: 86400

postgres:
  host: "postgres"
  port: 5432
  database: "docgen"
  user: "docgen"
  password: "docgen_password"

s3:
  endpoint_url: "http://localstack:4566"
  region: "us-east-1"
  access_key_id: "test"
  secret_access_key: "test"
  bucket: "source2doc-repos"

encryption_key: YOUR_ENCRYPTION_KEY_HERE

logfire:
  enabled: false
  token: null   # paste Logfire write token and set enabled: true to ship traces

# Path to agent prompts directory
# Can be relative (will be resolved to core/mvp/<path>) or absolute
# Default: "configs/agents" -> resolves to core/mvp/configs/agents
prompts_dir: "configs/agents"

# In-worker liveness HTTP server (TZ РЗВ-03).
# Defaults: docgen=8100, repos=8101, bundler=8102, codetour=8103.
# Leave health_port unset to use the per-mode default.
# health_host: 0.0.0.0
# health_port: 8101
