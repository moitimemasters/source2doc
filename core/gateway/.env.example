DEBUG=false
HOST=0.0.0.0
PORT=8003

REDIS__URL=redis://localhost:6379
REDIS__STREAM_PREFIX=pipeline
REDIS__CONSUMER_GROUP=workers
REDIS__CONSUMER_NAME=gateway-1

# Generate with: ../../generate-encryption-key.sh "your-passphrase"
# IMPORTANT: Must match ENCRYPTION_KEY in root .env and worker configs
ENCRYPTION_KEY=YOUR_ENCRYPTION_KEY_HERE

POSTGRES__HOST=localhost
POSTGRES__PORT=5432
POSTGRES__DATABASE=docgen
POSTGRES__USER=docgen
POSTGRES__PASSWORD=docgen_password

S3__ENDPOINT_URL=http://localhost:4566
S3__REGION=us-east-1
S3__ACCESS_KEY_ID=test
S3__SECRET_ACCESS_KEY=test
S3__BUCKET=source2doc-repos
