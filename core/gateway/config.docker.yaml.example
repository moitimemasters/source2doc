debug: false
host: 0.0.0.0
port: 8003
encryption_key: YOUR_ENCRYPTION_KEY_HERE

# Admin auth (boxed mode). Generate the bcrypt hash via:
#   ./generate-admin-password.sh
admin_username: admin
admin_password_hash: REPLACE_WITH_BCRYPT_HASH
session_ttl_hours: 24

# Set to false when running over plain HTTP locally so the admin cookie is sent.
cookie_secure: false
cookie_domain: null

redis:
  url: redis://redis:6379
  stream_prefix: events
  consumer_group: workers
  consumer_name: gateway-1
  block_timeout_ms: 5000
  max_idle_time_ms: 120000
  stream_ttl_seconds: 86400

postgres:
  host: postgres
  port: 5432
  database: docgen
  user: docgen
  password: YOUR_PASSWORD_HERE

qdrant:
  url: http://qdrant:6333
  collection: docgen
  api_key: null

s3:
  endpoint_url: http://localstack:4566
  region: us-east-1
  access_key_id: test
  secret_access_key: test
  bucket: source2doc-repos
