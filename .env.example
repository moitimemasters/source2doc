# PostgreSQL
POSTGRES_PASSWORD=docgen_password

# Redis
REDIS_URL=redis://redis:6379

# Encryption Key (generate with: ./generate-encryption-key.sh "your-passphrase")
# IMPORTANT: Use the same key for Gateway and all Workers
ENCRYPTION_KEY=YOUR_ENCRYPTION_KEY_HERE

# Gateway
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8003

# Workers
WORKER_ID=worker-1
POLL_INTERVAL_MS=1000
MAX_RETRIES=3
RETRY_DELAY_MS=5000

# S3 (LocalStack)
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=test
S3_SECRET_ACCESS_KEY=test
S3_ENDPOINT_URL=http://localhost:4566
S3_BUCKET=source2doc-repos

# UI
NEXT_PUBLIC_GATEWAY_URL=http://localhost:8003

# When the `app` profile is up, the canonical entry point is http://localhost/
# (Traefik on :80 routes /api/v1/* → gateway, everything else → UI). The legacy
# direct ports below are still exposed on host for dev convenience:
#   - UI direct:      http://localhost:3001
#   - Gateway direct: http://localhost:8003
#   - Traefik dash:   http://localhost:8080

# CodeTour (optional)
OPENAI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
QDRANT_URL=http://qdrant:6333
