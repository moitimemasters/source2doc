# Generated by ./bootstrap.sh. You should not edit this manually unless you
# know what you're doing. Run ./bootstrap.sh to get a working .env with a
# fresh Fernet key and a random admin password.

# Fernet key shared by gateway + workers (used to encrypt/decrypt per-task
# LLM configs in Redis and admin presets in Postgres).
ENCRYPTION_KEY=

# bcrypt hash of the gateway admin password. Generate with:
#   ./generate-admin-password.sh <plaintext>
ADMIN_PASSWORD_HASH=

# PostgreSQL password — passed to the postgres container and to gateway/workers
# via the templated config.docker.yaml files.
POSTGRES_PASSWORD=docgen_password
