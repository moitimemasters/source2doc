    },
    {
      "type": "paragraph",
      "text": "Explore advanced features of the wiki system including tables, images, quotes, and more."
    },
    {
      "type": "heading",
      "level": 2,
      "text": "Tables"
    },
    {
      "type": "paragraph",
      "text": "Tables are useful for presenting data in a structured format. Here's an example:"
    },
    {
      "type": "table",
      "headers": ["Feature", "Description", "Status"],
      "rows": [
        ["Headings", "Multiple heading levels (h1-h6)", "✓"],
        ["Paragraphs", "Rich text content", "✓"],
        ["Code Blocks", "Syntax highlighting", "✓"],
        ["Lists", "Ordered and unordered", "✓"],
        ["Tables", "Tabular data display", "✓"],
