// Declarative Jenkins pipeline for driving a deployed source2doc gateway.
//
// Required Jenkins credentials (Manage Jenkins -> Credentials):
//   source2doc-url       Secret Text   - base URL of the gateway
//   source2doc-username  Secret Text   - admin username
//   source2doc-password  Secret Text   - admin password
//
// Optional credentials:
//   source2doc-preset    Secret Text   - server-side LLM preset name
//
// Tools required on the agent: bash, curl, jq, tar.

pipeline {
    agent any

    options {
        timeout(time: 35, unit: 'MINUTES')
        ansiColor('xterm')
        disableConcurrentBuilds()
    }

    parameters {
        string(name: 'PIPELINE_ID', defaultValue: 'docgen', description: 'source2doc pipeline id')
        choice(name: 'BUNDLE_FORMAT', choices: ['mkdocs', 'nextra', 'sphinx'], description: 'Bundle output format')
        string(name: 'TARGET_BRANCH', defaultValue: '', description: 'Branch to document (defaults to BRANCH_NAME)')
    }

    environment {
        POLL_INTERVAL_SECONDS = '10'
        POLL_TIMEOUT_SECONDS  = '1800'
        COOKIE_JAR            = "${env.WORKSPACE}/cookies.txt"
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Generate documentation via source2doc') {
            steps {
                withCredentials([
                    string(credentialsId: 'source2doc-url',      variable: 'SOURCE2DOC_URL'),
                    string(credentialsId: 'source2doc-username', variable: 'SOURCE2DOC_USERNAME'),
                    string(credentialsId: 'source2doc-password', variable: 'SOURCE2DOC_PASSWORD'),
                ]) {
                    sh '''#!/usr/bin/env bash
set -euo pipefail

TARGET_BRANCH="${TARGET_BRANCH:-${BRANCH_NAME:-main}}"
PRESET="${SOURCE2DOC_PRESET:-}"

echo "Logging in..."
rm -f "${COOKIE_JAR}"
status=$(curl --silent --show-error --output login.json --write-out '%{http_code}' \\
    -c "${COOKIE_JAR}" \\
    -H 'Content-Type: application/json' \\
    -X POST \\
    --data "$(jq -n --arg u "${SOURCE2DOC_USERNAME}" --arg p "${SOURCE2DOC_PASSWORD}" '{username:$u,password:$p}')" \\
    "${SOURCE2DOC_URL%/}/api/v1/admin/auth/login")
if [ "${status}" != "200" ]; then
    echo "Login failed with HTTP ${status}" >&2
    cat login.json || true
    exit 1
fi

echo "Packaging working tree..."
archive_name="repo-${BUILD_NUMBER}.tar.gz"
tar --exclude-vcs --exclude='Jenkinsfile' -czf "${archive_name}" -C "${WORKSPACE}" .

echo "Uploading repository..."
repo_name="${JOB_NAME}@${TARGET_BRANCH}"
status=$(curl --silent --show-error --output upload.json --write-out '%{http_code}' \\
    -b "${COOKIE_JAR}" \\
    -F "file=@${archive_name}" \\
    -F "name=${repo_name}" \\
    -F "description=Jenkins build ${BUILD_NUMBER}" \\
    "${SOURCE2DOC_URL%/}/api/v1/repos/upload")
if [ "${status}" != "200" ]; then
    echo "Upload failed with HTTP ${status}" >&2
    cat upload.json || true
    exit 1
fi
REPO_ID=$(jq -r '.repo_id' upload.json)
test -n "${REPO_ID}" && test "${REPO_ID}" != "null"
echo "repo_id=${REPO_ID}"

echo "Creating generation task..."
payload=$(jq -n \\
    --arg repo_id "${REPO_ID}" \\
    --arg name "${JOB_NAME} (${TARGET_BRANCH})" \\
    --arg description "Jenkins build ${BUILD_NUMBER}" \\
    --arg preset "${PRESET}" \\
    '{repo_id:$repo_id, name:$name, description:$description}
     + (if $preset == "" then {} else {preset:$preset} end)')
status=$(curl --silent --show-error --output task.json --write-out '%{http_code}' \\
    -b "${COOKIE_JAR}" \\
    -H 'Content-Type: application/json' \\
    -X POST \\
    --data "${payload}" \\
    "${SOURCE2DOC_URL%/}/api/v1/tasks")
if [ "${status}" != "200" ]; then
    echo "Task creation failed with HTTP ${status}" >&2
    cat task.json || true
    exit 1
fi
GEN_ID=$(jq -r '.generation_id' task.json)
test -n "${GEN_ID}" && test "${GEN_ID}" != "null"
echo "generation_id=${GEN_ID}"

echo "Polling for completion..."
deadline=$(( $(date +%s) + POLL_TIMEOUT_SECONDS ))
final_status="unknown"
while [ "$(date +%s)" -lt "${deadline}" ]; do
    if ! curl --silent --show-error --fail \\
            -b "${COOKIE_JAR}" \\
            "${SOURCE2DOC_URL%/}/api/v1/streams/${GEN_ID}/events" \\
            -o events.json; then
        sleep "${POLL_INTERVAL_SECONDS}"
        continue
    fi
    recent_types=$(jq -r '[.[].type] | reverse | .[0:20] | .[]' events.json || true)
    if echo "${recent_types}" | grep -qx 'generation.completed'; then
        final_status="completed"
        break
    fi
    if echo "${recent_types}" | grep -qxE 'generation\\.failed|task\\.failed|step\\.failed'; then
        final_status="failed"
        break
    fi
    sleep "${POLL_INTERVAL_SECONDS}"
done
if [ "${final_status}" = "failed" ]; then
    echo "Pipeline reported failure" >&2
    jq '.' events.json | tail -n 200 || true
    exit 1
fi
if [ "${final_status}" != "completed" ]; then
    echo "Polling timed out after ${POLL_TIMEOUT_SECONDS}s" >&2
    exit 1
fi

echo "Resolving bundle id..."
curl --silent --show-error --fail -b "${COOKIE_JAR}" \\
    "${SOURCE2DOC_URL%/}/api/v1/docs/bundles?limit=200" -o bundles.json
BUNDLE_ID=$(jq -r --arg gid "${GEN_ID}" '.bundles[] | select(.generation_id==$gid) | .id' bundles.json | head -n1)
test -n "${BUNDLE_ID}" && test "${BUNDLE_ID}" != "null"
echo "bundle_id=${BUNDLE_ID}"

echo "Requesting ${BUNDLE_FORMAT} export..."
payload=$(jq -n \\
    --argjson bundle_id "${BUNDLE_ID}" \\
    --arg generation_id "${GEN_ID}" \\
    --arg format "${BUNDLE_FORMAT}" \\
    '{bundle_id:$bundle_id, generation_id:$generation_id, format:$format}')
status=$(curl --silent --show-error --output export.json --write-out '%{http_code}' \\
    -b "${COOKIE_JAR}" \\
    -H 'Content-Type: application/json' \\
    -X POST \\
    --data "${payload}" \\
    "${SOURCE2DOC_URL%/}/api/v1/bundles/export")
if [ "${status}" != "200" ]; then
    echo "Bundle export request failed with HTTP ${status}" >&2
    cat export.json || true
    exit 1
fi

echo "Waiting for bundle archive..."
deadline=$(( $(date +%s) + POLL_TIMEOUT_SECONDS ))
S3_KEY=""
while [ "$(date +%s)" -lt "${deadline}" ]; do
    curl --silent --show-error --fail \\
        -b "${COOKIE_JAR}" \\
        "${SOURCE2DOC_URL%/}/api/v1/bundles/exports?bundle_id=${BUNDLE_ID}" \\
        -o exports.json || true
    S3_KEY=$(jq -r --arg fmt "${BUNDLE_FORMAT}" \\
        '.exports[] | select(.format==$fmt) | .s3_key' exports.json 2>/dev/null | head -n1 || true)
    if [ -n "${S3_KEY}" ] && [ "${S3_KEY}" != "null" ]; then
        break
    fi
    sleep "${POLL_INTERVAL_SECONDS}"
done
if [ -z "${S3_KEY}" ] || [ "${S3_KEY}" = "null" ]; then
    echo "Bundle archive never appeared in S3" >&2
    exit 1
fi

echo "Downloading bundle..."
encoded=$(jq -rn --arg k "${S3_KEY}" '$k|@uri')
curl --silent --show-error --fail \\
    -b "${COOKIE_JAR}" \\
    "${SOURCE2DOC_URL%/}/api/v1/bundles/exports/download?s3_key=${encoded}" \\
    -o "source2doc-${BUNDLE_FORMAT}.tar.gz"
ls -la "source2doc-${BUNDLE_FORMAT}.tar.gz"
'''
                }
            }
        }
    }

    post {
        always {
            withCredentials([
                string(credentialsId: 'source2doc-url', variable: 'SOURCE2DOC_URL'),
            ]) {
                sh '''#!/usr/bin/env bash
set +e
if [ -f "${COOKIE_JAR}" ]; then
    curl --silent --show-error \\
        -b "${COOKIE_JAR}" \\
        -X POST \\
        "${SOURCE2DOC_URL%/}/api/v1/admin/auth/logout" \\
        -o /dev/null || true
    rm -f "${COOKIE_JAR}"
fi
'''
            }
        }
        success {
            archiveArtifacts artifacts: "source2doc-${params.BUNDLE_FORMAT}.tar.gz", allowEmptyArchive: false, fingerprint: true
        }
    }
}
